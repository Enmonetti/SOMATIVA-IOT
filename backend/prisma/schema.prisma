generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id    Int    @id @default(autoincrement())
  name  String

  users User[]
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  password  String

  profileId Int
  profile   Profile @relation(fields: [profileId], references: [id])

  comments Comment[]
}

model Equipment {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  imageUrl    String
  status      Boolean

  createdAt DateTime @default(now())

  comments  Comment[]
  telemetry Telemetry[]
}

model Comment {
  id          Int      @id @default(autoincrement())
  description String

  createdAt DateTime @default(now())

  equipmentId Int
  userId      Int

  equipment Equipment @relation(fields: [equipmentId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model Telemetry {
  id                 Int      @id @default(autoincrement())

  temperature        Float
  vibration          Float
  currentConsumption Float

  timestamp DateTime @default(now())

  equipmentId Int
  equipment Equipment @relation(fields: [equipmentId], references: [id])
}